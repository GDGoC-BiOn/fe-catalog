# Catalog remote micro-frontend configuration.
# Copy to `.env` for local dev, or set as environment variables on deploy.
# No trailing slashes on URLs.

# Public origin where the catalog is served. Used as Vite `base` so the host can
# load this remote's chunks cross-origin. Must serve /remoteEntry.js with CORS.
VITE_PUBLIC_URL=https://catalog.example.com
# Port the dev/preview server binds to (ignored by most static hosts).
VITE_PORT=3001
